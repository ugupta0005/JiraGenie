{
  "compilerOptions": {
    "target": "ES2015",
    "module": "None",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./public/js",
    "rootDir": "./src-frontend",
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src-frontend/main.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
